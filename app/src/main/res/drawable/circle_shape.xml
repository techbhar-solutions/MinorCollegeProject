<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Circle ka background color -->
    <solid android:color="@color/inputboxcolor"/>  <!-- Yahan apna desired color daale -->

    <!-- Border (optional) -->
    <stroke
        android:width="2dp"
        android:color="#000000"/>  <!-- Yahan border color daale -->

    <!-- Padding (optional) -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp"/>
</shape>
